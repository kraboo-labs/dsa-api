DSA_ENVIRONMENT=development
DSA_DEBUG=true

DSA_DATABASE_URL=postgresql+asyncpg://dsa:dsa@localhost:5433/dsa
DSA_REDIS_URL=redis://localhost:6379/0

DSA_SOURCE_URL=https://digital-strategy.ec.europa.eu/en/policies/trusted-flaggers-under-dsa
DSA_USER_AGENT=dsa-api-scraper/0.1 (+https://dsa-api.com)

# DSA_SENTRY_DSN=https://...@sentry.io/...

